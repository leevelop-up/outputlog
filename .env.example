# NAS 서버 배포용 환경변수
# 이 파일을 복사해서 .env로 만들고 값을 채우세요

# DB
DB_USERNAME=outputlog
DB_PASSWORD=outputlog1234      # 변경 필수

# Redis
REDIS_PASSWORD=redis1234       # 변경 필수

# JWT (32자 이상 랜덤 문자열)
JWT_SECRET=outputlog-jwt-secret-key-must-be-at-least-256-bits-long!!

# 프론트엔드가 API 호출할 주소
# 외부 도메인이 있으면: https://your-domain.com/api
VITE_API_BASE_URL=/api

# CORS — 프론트 접속 URL
CORS_ORIGINS=http://NAS_IP

# 포트 (기본 80)
PORT=80

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth 로그인 후 리다이렉트될 프론트엔드 주소
OAUTH2_REDIRECT_URI=https://outputlog.com/oauth-callback
